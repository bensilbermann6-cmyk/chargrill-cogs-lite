# Copy this to secrets.toml for local dev, or paste these four keys into
# Streamlit Cloud → app → Settings → Secrets. Never commit the real secrets.toml.

APP_PASSWORD = "choose-a-password-for-this-store"
SUPABASE_URL = "https://your-project.supabase.co"
SUPABASE_KEY = "your-service_role-key"      # service_role, NOT anon
ANTHROPIC_API_KEY = "sk-ant-..."            # the one shared key, reused across stores
